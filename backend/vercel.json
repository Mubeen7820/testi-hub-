{
  "version": 2,
  "functions": {
    "src/index.ts": {
      "runtime": "@vercel/node",
      "includeFiles": "prisma/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.ts"
    },
    {
      "src": "/health",
      "dest": "src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ]
}
